# ── Base de datos ─────────────────────────────────────────────────────────────
# Copia esto desde Railway > tu proyecto > PostgreSQL > Connect
DATABASE_URL=postgresql://usuario:password@host:5432/railway

# ── JWT ───────────────────────────────────────────────────────────────────────
# Cadena aleatoria larga — genera una en: https://generate-secret.vercel.app/64
JWT_SECRET=cambia_esto_por_algo_muy_largo_y_seguro_min_64_chars

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# En producción pon tu dominio de Vercel
FRONTEND_URL=http://localhost:5500

# ── Facturapi (CFDI SAT) ─────────────────────────────────────────────────────
# Obtén tu API key en https://www.facturapi.io
# Cada empresa tiene su propia key (se guarda en la tabla empresas)
# Esta es la key de tu cuenta ServiGest para crear organizaciones
FACTURAPI_SECRET_KEY=sk_test_XXXXXXXX

# ── Archivos / Uploads ────────────────────────────────────────────────────────
# Tamaño máximo de archivo para importación Excel (en bytes)
MAX_UPLOAD_SIZE=5242880

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
